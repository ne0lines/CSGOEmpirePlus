{
  "manifest_version": 3,
  "name": "CSGOEmpirePlus",
  "version": "1.0.1",
  "description": "Gain extra features on CSGOEmpire",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },

  "host_permissions": [
    "https://csgoempire.com/*",
    "https://extension.ne0lines.xyz/*",
    "https://api.pricempire.com/*",
    "https://pricempire.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "scripts/pricempire-utils.js",
        "scripts/fetch-injector.js",
        "scripts/network-sniffer.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": [
        "https://csgoempire.com/*",
        "https://csgoempire.gg/*",
        "https://csgoempire.tv/*",
        "https://csgoempiretr.com/*",
        "https://csgoempire88.com/*",
        "https://csgoempire.cam/*",
        "https://csgoempirev2.com/*",
        "https://csgoempire.io/*", 
        "https://csgoempire.info/*",
        "https://csgoempire.vip/*",
        "https://csgoempire.fun/*",
        "https://csgoempire.biz/*",
        "https://csgoempire.vegas/*",
        "https://csgoempire.link/*"
      ],
      "js": [
        "scripts/fetch-injector.js",
        "thirdParty/jquery-3.7.1-min.js",
        "scripts/pricempire-utils.js",
        "thirdParty/apexcharts.min.js",
        "scripts/dom-content.js",
        "scripts/chrome-background.js",
        "scripts/utility-functions.js",
        "scripts/bookmark-manager.js",
        "scripts/ui-manager.js",
        "scripts/grid-helper.js",
        "scripts/pricing-fetcher.js",
        "scripts/network-sniffer.js",
        "scripts/table-enhancer.js",
        "scripts/route-handler.js",
        "scripts/initializer.js",
        "scripts/pricempire-panel.js"
      ],
      "css": ["css/style.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],

  "background": {
    "service_worker": "scripts/background.js"
  }
}
